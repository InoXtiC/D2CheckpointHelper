                            <i data-lucide="activity" class="w-4 h-4 text-amber-500"></i> [03] Modifier Protocols
                        </h3>
                        <p class="text-[11px] text-slate-400">Master difficulty is restricted based on current operational cycle schedules.</p>
                    </div>
                    
                    <!-- Difficulty button selections styled to look like Destiny interface plates -->
                    <div class="flex w-full md:w-auto p-1 bg-slate-950 border border-slate-900 rounded-sm" id="difficulty-wrapper">
                        <button 
                            id="diff-normal" 
                            onclick="setDifficulty(false)" 
                            class="flex-1 md:flex-none flex items-center justify-center gap-2 px-6 py-2.5 rounded-sm text-xs font-bold tracking-wider uppercase transition-all text-amber-500 bg-amber-500/10 border border-amber-500/20"
                        >
                            <i data-lucide="shield" class="w-3.5 h-3.5"></i> NORMAL
                        </button>
                        <button 
                            id="diff-master" 
                            onclick="setDifficulty(true)" 
                            class="flex-1 md:flex-none flex items-center justify-center gap-2 px-6 py-2.5 rounded-sm text-xs font-bold tracking-wider uppercase transition-all text-slate-600 hover:text-slate-400"
                        >
                            <i data-lucide="skull" class="w-3.5 h-3.5 text-amber-600"></i> MASTER
                        </button>
                    </div>
                </div>
            </div>

        </section>

        <!-- Right Section (Lg: 4 cols): Output HUD, Console & Operational Guides -->
        <section class="lg:col-span-4 flex flex-col gap-6">
            
            <!-- Vanguard Comm Network Frame -->
            <div class="destiny-panel tech-corners p-6 rounded-sm flex flex-col justify-between gap-6 relative overflow-hidden bg-gradient-to-b from-[#070b13] to-[#020408]">
                <!-- Interactive grid background and radar graphic mock -->
                <div class="absolute top-0 right-0 w-32 h-32 bg-amber-500/[0.02] rounded-full blur-2xl pointer-events-none"></div>
                <div class="absolute -bottom-8 -left-8 w-24 h-24 bg-indigo-500/[0.01] rounded-full blur-xl pointer-events-none"></div>

                <div class="space-y-4">
                    <div class="flex items-center justify-between border-b border-slate-900 pb-3">
                        <div class="flex items-center gap-2">
                            <span class="w-2 h-2 rounded-full bg-amber-500 animate-pulse"></span>
                            <span class="text-xs font-bold tracking-wider text-amber-500 uppercase">TRANSMISSION FREQUENCY</span>
                        </div>
                        <span class="text-[9px] text-amber-500/80 bg-amber-500/10 px-2 py-0.5 border border-amber-500/20 font-bold uppercase tracking-widest font-mono">COMMS LINK</span>
                    </div>

                    <!-- Generated Queue String HUD element -->
                    <div class="space-y-1.5">
                        <span class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">TRANSMIT PACKET PREVIEW</span>
                        <div class="bg-slate-950 border border-slate-900 hover:border-amber-500/30 rounded-sm p-4 min-h-[90px] flex items-center justify-center transition-all">
                            <p id="queueString" class="mono-font text-center text-amber-400 font-bold break-all text-sm tracking-widest select-all uppercase">
                                !queue se 1 n
                            </p>
                        </div>
                    </div>
                </div>

                <div class="space-y-2.5">
                    <button 
                        type="button" 
                        onclick="copyCommand()" 
                        class="w-full flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-600 text-slate-950 font-bold py-3 px-4 rounded-sm transition-all duration-200 text-xs tracking-widest uppercase hover:shadow-[0_0_15px_rgba(245,166,35,0.4)]"
                    >
                        <i data-lucide="copy" class="w-4 h-4"></i> Copy Telemetry
                    </button>
                    <p class="text-[9px] text-center text-slate-500 tracking-wider">Send compiled parameters directly into active active terminal console channels.</p>
                </div>
            </div>

            <!-- Live Terminal Interactive Logging Panel -->
            <div class="destiny-panel tech-corners p-4 rounded-sm bg-black/90">
                <div class="flex items-center justify-between border-b border-slate-900 pb-2 mb-2">
                    <span class="text-[9px] font-bold text-amber-500 tracking-widest flex items-center gap-1.5 uppercase">
                        <i data-lucide="terminal" class="w-3 h-3 text-amber-500 animate-pulse"></i> LIVE MONITOR
                    </span>
                    <span class="text-[8px] font-mono text-emerald-500/80">LINK_SECURE</span>
                </div>
                <!-- Interactive Log Container -->
                <div id="terminal-logs" class="mono-font text-[9px] leading-relaxed text-slate-500 h-24 overflow-y-auto pr-1">
                    <p class="text-emerald-400">[VANGUARD] Established secure link to Director.</p>
                    <p class="text-slate-600">[SYS] Ready for telemetry initialization.</p>
                </div>
            </div>

            <!-- Vanguard Security Core Directive FAQ -->
            <div class="destiny-panel tech-corners p-6 rounded-sm flex flex-col gap-4">
                <h3 class="text-xs font-bold tracking-widest text-amber-500 flex items-center gap-2 uppercase">
                    <i data-lucide="book" class="w-4 h-4"></i> Operation Manual
                </h3>
                <div class="text-[11px] text-slate-400 space-y-4">
                    <div class="flex items-start gap-2.5">
                        <div class="w-4 h-4 rounded-full bg-slate-900 border border-slate-800 flex items-center justify-center text-[10px] font-bold text-amber-500 font-mono flex-shrink-0">1</div>
                        <div class="flex-1 space-y-0.5">
                            <p class="font-bold text-slate-300 uppercase tracking-wider">IDENTIFY GUARD</p>
                            <p>Select or enter your Bungie Name. Valid profiles are auto-memorized.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-2.5">
                        <div class="w-4 h-4 rounded-full bg-slate-900 border border-slate-800 flex items-center justify-center text-[10px] font-bold text-amber-500 font-mono flex-shrink-0">2</div>
                        <div class="flex-1 space-y-0.5">
                            <p class="font-bold text-slate-300 uppercase tracking-wider">CHOOSE DESTINATION</p>
                            <p>Select standard activities folder followed by target checkpoint sector.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-2.5">
                        <div class="w-4 h-4 rounded-full bg-slate-900 border border-slate-800 flex items-center justify-center text-[10px] font-bold text-amber-500 font-mono flex-shrink-0">3</div>
                        <div class="flex-1 space-y-0.5">
                            <p class="font-bold text-slate-300 uppercase tracking-wider">DISPATCH SIGNAL</p>
                            <p>Copy compiled parameters, insert into logs, accept game invite & enjoy.</p>
                        </div>
                    </div>
                </div>
            </div>

        </section>

    </main>

    <!-- Footer Area -->
    <footer class="border-t border-slate-900 bg-slate-950/80 py-5 mt-12 text-slate-500 relative">
        <div class="max-w-7xl mx-auto px-4 text-center space-y-1">
            <p class="text-[11px] tracking-wider">
                TRAVELER'S CHOSEN TERMINAL ARCHITECTURE // AUTHENTICATED ACCESS ONLY
            </p>
            <p class="text-[9px] text-slate-600">
                Independent vanguard application. Destiny 2, Destiny, and all associated images and assets remain property of Bungie, Inc.
            </p>
        </div>
    </footer>

    <!-- Custom Destiny UI Toast Overlay -->
    <div id="toast" class="fixed bottom-6 right-6 z-50 transform translate-y-12 opacity-0 pointer-events-none transition-all duration-300 ease-out flex items-center gap-3 bg-slate-950 border border-amber-500/30 shadow-[0_0_20px_rgba(245,166,35,0.15)] rounded-sm p-4 text-slate-200">
        <div class="p-1 bg-amber-500/10 rounded-sm border border-amber-500/30">
            <i data-lucide="check-circle" class="w-4 h-4 text-amber-500"></i>
        </div>
        <div class="flex flex-col">
            <span id="toast-title" class="text-xs font-bold text-amber-500 uppercase tracking-wider">Terminal Dispatch</span>
            <span id="toast-message" class="text-[10px] text-slate-400">Custom message goes here</span>
        </div>
    </div>

