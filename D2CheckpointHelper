                        type="text" 
                        id="search-input" 
                        oninput="filterActivities()" 
                        placeholder="Search standard files, records & logs..." 
                        class="w-full bg-slate-950 border border-slate-900 focus:border-amber-500/40 rounded-sm pl-9 pr-4 py-2.5 text-xs text-slate-300 placeholder-slate-700 focus:outline-none transition-all focus:ring-1 focus:ring-amber-500/20"
                    >
                </div>

                <!-- Split Navigation Interface: Activity vs Encounter Selection -->
                <div class="grid grid-cols-1 md:grid-cols-12 gap-6 min-h-[300px]">
                    
                    <!-- Left Column (6 cols): Primary Activities List -->
                    <div class="md:col-span-6 flex flex-col gap-2">
                        <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400 mb-1 flex items-center gap-1.5">
                            <i data-lucide="chevron-right" class="w-3 h-3 text-amber-500"></i> Operation Folder
                        </h3>
                        <div id="activities-grid" class="flex flex-col gap-1.5 max-h-[300px] overflow-y-auto pr-2">
                            <!-- Activities populated dynamically -->
                        </div>
                    </div>

                    <!-- Right Column (6 cols): Available Checkpoint Encounters list -->
                    <div class="md:col-span-6 flex flex-col gap-2 border-t md:border-t-0 md:border-l border-slate-900 pt-4 md:pt-0 md:pl-6">
                        <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400 mb-1 flex items-center gap-1.5">
                            <i data-lucide="chevron-right" class="w-3 h-3 text-amber-500"></i> Sector Record
                        </h3>
                        <div id="encounters-grid" class="flex flex-col gap-1.5 max-h-[300px] overflow-y-auto pr-2">
                            <!-- Helper text shown when nothing is selected -->
                            <div id="encounter-placeholder" class="text-center py-16 text-slate-700 flex flex-col items-center gap-3">
                                <i data-lucide="binary" class="w-8 h-8 text-slate-800 animate-pulse"></i>
                                <p class="text-xs">Establish communications to read record blocks.</p>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- STEP 3: Intensity & Difficulty Modifier Selector -->
