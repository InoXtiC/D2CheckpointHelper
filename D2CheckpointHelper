                <!-- Decorative Top Tech Accent Bar -->
                <div class="absolute top-0 left-1/4 right-1/4 h-[1px] bg-gradient-to-r from-transparent via-amber-500/60 to-transparent"></div>
                
                <div class="flex flex-col gap-4">
                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                        <div class="space-y-1">
                            <label for="bungiename" class="text-xs font-bold tracking-widest text-amber-500 flex items-center gap-2 uppercase">
                                <i data-lucide="user-check" class="w-4 h-4"></i> [01] Guardian Identifier
                            </label>
                            <p class="text-[11px] text-slate-400">Must include unique bungie index identifier, e.g. <code>Guardian#1234</code></p>
                        </div>
                        
                        <!-- Validation input wrapper -->
                        <div class="relative w-full md:w-80">
                            <input 
                                type="text" 
                                id="bungiename" 
                                onkeyup="onBungieNameChange()"
                                placeholder="GUARDIAN#0000" 
                                class="w-full bg-slate-950 border border-slate-800 focus:border-amber-500 rounded-sm px-4 py-2.5 text-slate-100 placeholder-slate-700 focus:outline-none transition-all text-sm tracking-wider uppercase mono-font focus:ring-1 focus:ring-amber-500/30"
                            >
                            <!-- Validation Badge -->
                            <div id="validation-badge" class="absolute right-2 top-2.5 flex items-center gap-1 text-[10px] font-bold px-2 py-0.5 rounded text-rose-400 bg-rose-500/10 border border-rose-500/20">
                                <i data-lucide="x-circle" id="validation-icon" class="w-3.5 h-3.5"></i>
                                <span id="validation-text">Incomplete</span>
                            </div>
                        </div>
                    </div>

                    <!-- Guardian Profile Manager Widget (History List) -->
                    <div class="border-t border-slate-900 pt-3">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-[10px] font-bold text-slate-500 tracking-wider uppercase flex items-center gap-1.5">
                                <i data-lucide="history" class="w-3 h-3"></i> Profile Registry History
                            </span>
                            <button onclick="clearHistory()" class="text-[9px] text-rose-400 hover:text-rose-300 transition-colors uppercase font-semibold flex items-center gap-1">
                                <i data-lucide="trash-2" class="w-2.5 h-2.5"></i> Clear Records
                            </button>
                        </div>
                        
                        <!-- Saved Profile Buttons (populated dynamically) -->
                        <div id="saved-guardians-list" class="flex flex-wrap gap-1.5">
                            <span class="text-[11px] text-slate-600 italic py-1">No previous Guardians saved on this terminal.</span>
                        </div>
                    </div>

                </div>
            </div>

            <!-- STEP 2: Activity Dispatch Grid -->
