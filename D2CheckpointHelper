<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Destiny 2 Checkpoint Bot Queue Helper</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap');
        
        body {
            font-family: 'Space Grotesk', sans-serif;
            background-color: #040811;
            /* Starry nebula theme combined with grid scanlines */
            background-image: 
                radial-gradient(at 0% 0%, rgba(13, 27, 42, 0.85) 0, transparent 60%),
                radial-gradient(at 100% 0%, rgba(245, 166, 35, 0.08) 0, transparent 40%),
                radial-gradient(at 50% 100%, rgba(30, 41, 59, 0.9) 0, transparent 70%),
                linear-gradient(rgba(245, 166, 35, 0.01) 1px, transparent 1px),
                linear-gradient(90deg, rgba(245, 166, 35, 0.01) 1px, transparent 1px);
            background-size: 100% 100%, 100% 100%, 100% 100%, 32px 32px, 32px 32px;
            background-attachment: fixed;
            overflow-x: hidden;
        }

        /* Ambient scanline overlay */
        .scanlines::after {
            content: " ";
            display: block;
            position: fixed;
            top: 0; left: 0; bottom: 0; right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.03));
            z-index: 9999;
            background-size: 100% 4px, 6px 100%;
            pointer-events: none;
            opacity: 0.45;
        }

        .mono-font {
            font-family: 'JetBrains Mono', monospace;
        }

        /* Destiny Vanguard style angled borders and glowing states */
        .destiny-panel {
            background: rgba(4, 7, 14, 0.93);
            border: 1px solid rgba(245, 166, 35, 0.1);
            box-shadow: inset 0 0 20px rgba(245, 166, 35, 0.02);
            position: relative;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .destiny-panel:hover {
            border-color: rgba(245, 166, 35, 0.35);
            box-shadow: 0 0 30px rgba(245, 166, 35, 0.04), inset 0 0 20px rgba(245, 166, 35, 0.05);
        }

        /* Angled tech accent corners */
        .tech-corners::before {
            content: '';
            position: absolute;
            top: -1px;
            left: -1px;
            width: 12px;
            height: 12px;
            border-top: 3px solid rgba(245, 166, 35, 0.85);
            border-left: 3px solid rgba(245, 166, 35, 0.85);
            z-index: 10;
        }

        .tech-corners::after {
            content: '';
            position: absolute;
            bottom: -1px;
            right: -1px;
            width: 12px;
            height: 12px;
            border-bottom: 3px solid rgba(245, 166, 35, 0.85);
            border-right: 3px solid rgba(245, 166, 35, 0.85);
            z-index: 10;
        }

        /* Pulse and loading animations */
        @keyframes network-activity {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 1; filter: drop-shadow(0 0 4px rgba(245, 166, 35, 0.8)); }
        }
        .network-active {
            animation: network-activity 2s infinite ease-in-out;
        }

        /* Custom scrollbars */
        ::-webkit-scrollbar {
            width: 4px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(4, 7, 12, 0.95);
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(245, 166, 35, 0.3);
            border-radius: 2px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(245, 166, 35, 0.75);
        }
    </style>
</head>
<body class="min-h-screen text-slate-200 flex flex-col justify-between scanlines relative">

    <!-- Glowing Background Atmosphere Layer -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden z-0">
        <div class="absolute -top-40 left-1/4 w-[600px] h-[600px] bg-amber-500/[0.03] rounded-full blur-[160px]"></div>
        <div class="absolute bottom-10 right-10 w-[400px] h-[400px] bg-cyan-500/[0.02] rounded-full blur-[140px]"></div>
    </div>

    <!-- Destiny Top Navigation Bar -->
    <header class="border-b border-amber-500/25 bg-slate-950/95 backdrop-blur-md sticky top-0 z-50 relative">
        <div class="max-w-7xl mx-auto px-4 py-4 flex flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <!-- Vanguard Tricorn Stylized SVG -->
                <div class="p-2 bg-amber-500/10 rounded-sm border border-amber-500/40 shadow-[0_0_10px_rgba(245,166,35,0.15)]">
                    <svg class="w-8 h-8 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M12 2L4 7v10l8 5 8-5V7l-8-5z" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M12 2v20M20 7l-8 5-8-5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div>
                    <h1 class="text-base sm:text-xl font-bold tracking-[0.25em] text-white flex items-center gap-2">
                        TRAVELER'S CHOSEN
                    </h1>
                    <p class="text-[9px] text-amber-500/60 tracking-[0.3em] uppercase">Vanguard Terminal Access Control</p>
                </div>
            </div>
            
            <!-- Live Terminal Status Beacon -->
            <div class="flex items-center gap-2 px-3 py-1 bg-amber-500/10 border border-amber-500/25 rounded-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-amber-500 network-active"></span>
                <span class="text-[9px] font-mono tracking-widest text-amber-400 uppercase">DIRECTOR // CONSOLE_ONLINE</span>
            </div>
        </div>
    </header>

    <!-- Main Interactive Workspace -->
    <main class="max-w-7xl w-full mx-auto p-4 flex-grow grid grid-cols-1 lg:grid-cols-12 gap-6 mt-4 relative z-10">
        
