        // Save valid Guardian identities
        function saveGuardian(name) {
            // Avoid duplicates
            if (savedGuardians.some(g => g.toLowerCase() === name.toLowerCase())) {
                return;
            }
            // Keep up to 5 profiles
            savedGuardians.unshift(name);
            if (savedGuardians.length > 5) {
                savedGuardians.pop();
            }

            try {
                localStorage.setItem('tc_guardians_history', JSON.stringify(savedGuardians));
            } catch (e) {
                console.warn("Local storage write error", e);
            }
            renderHistoryUI();
            appendTerminalLog(`[REGISTRY] Saved guardian: ${name}`);
        }

        // Delete single guardian history record
        function deleteGuardian(event, name) {
            event.stopPropagation(); // prevent calling selectSavedGuardian
            playSciFiAudio('click');
            savedGuardians = savedGuardians.filter(g => g.toLowerCase() !== name.toLowerCase());
            
            try {
                localStorage.setItem('tc_guardians_history', JSON.stringify(savedGuardians));
            } catch (e) {
                console.warn("Local storage write error", e);
            }
            
            // If deleting currently active profile, clear selection state
            if (currentBungieName.toLowerCase() === name.toLowerCase()) {
                document.getElementById("bungiename").value = "";
                onBungieNameChange();
            }
            
            renderHistoryUI();
            showToast(`Removed profile: ${name}`);
            appendTerminalLog(`[REGISTRY] Deleted record: ${name}`);
        }

        // Flush entire history stack
        function clearHistory() {
            playSciFiAudio('click');
            savedGuardians = [];
            try {
                localStorage.removeItem('tc_guardians_history');
            } catch (e) {
                console.warn("Local storage delete error", e);
            }
            document.getElementById("bungiename").value = "";
            onBungieNameChange();
            renderHistoryUI();
            showToast("Cleared profile history database.");
            appendTerminalLog(`[REGISTRY] Registry fully flushed.`);
        }

