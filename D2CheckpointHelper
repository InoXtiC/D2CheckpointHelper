                        <button id="tab-dungeons" onclick="changeCategory('dungeons')" class="flex items-center gap-1.5 px-3 py-1.5 rounded-sm text-xs font-bold transition-all text-slate-400 hover:text-slate-200">
                            <i data-lucide="shield-alert" class="w-3.5 h-3.5"></i> Dungeons
                        </button>
