        // Cross-platform copy operation
        function copyCommand() {
            const textToCopy = document.getElementById("queueString").innerText;
            
            // Generate warning if details are empty
            if (!selectedActivity || !selectedEncounter || !currentBungieName) {
                playSciFiAudio('beep');
                showToast("Missing active parameters. Double check setup before sending!", "Link Warning");
                appendTerminalLog("[WARNING] Attempted telemetry transfer with missing fields.", true);
                return;
            }

            // Create invisible utility element for execution
            const textArea = document.createElement("textarea");
            textArea.value = textToCopy;
            textArea.style.position = "fixed"; 
            document.body.appendChild(textArea);
            textArea.focus();
            textArea.select();

            try {
                const successful = document.execCommand('copy');
                if (successful) {
                    playSciFiAudio('success');
                    showToast("Telemetry data copied to system board.", "Link Copied");
                    appendTerminalLog(`[DISPATCH] Secure packet exported: "${textToCopy.toUpperCase()}"`);
                } else {
                    showToast("Copying failed. Please highlight and copy manually.", "Link Copy Failed");
                }
            } catch (err) {
                showToast("System clipboard write restriction encountered.", "Link Copy Failed");
            }

            document.body.removeChild(textArea);
        }
    </script>
</body>
</html>
